FROM xpkg.upbound.io/upbound/function-go-templating:v0.11.3 AS func-go-templ-source
FROM xpkg.upbound.io/crossplane-contrib/function-auto-ready:v0.2.1 AS func-auto-ready-source
FROM xpkg.upbound.io/crossplane-contrib/function-sequencer:v0.1.0 AS func-sequencer-source

FROM golang:1.24-alpine

RUN apk add --no-cache bash curl git jq netcat-openbsd coreutils build-base

RUN curl -L https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 -o /usr/bin/yq && \
    chmod +x /usr/bin/yq

RUN curl -sL https://raw.githubusercontent.com/crossplane/crossplane/master/install.sh | sh && \
    mv crossplane /usr/bin/crossplane

RUN curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 && \
    chmod 700 get_helm.sh && \
    VERIFY_CHECKSUM=false ./get_helm.sh && \
    rm get_helm.sh

RUN curl -L https://github.com/yannh/kubeconform/releases/latest/download/kubeconform-linux-amd64.tar.gz | tar xz && \
    mv kubeconform /usr/bin/kubeconform && \
    chmod +x /usr/bin/kubeconform

COPY --from=func-go-templ-source /function /usr/bin/function-go-templating
COPY --from=func-auto-ready-source /function /usr/bin/function-auto-ready
COPY --from=func-sequencer-source  /function /usr/bin/function-sequencer

WORKDIR /workspace

COPY functions/ functions/

RUN for dir in $(find functions -name "go.mod" -exec dirname {} \;); do \
      echo "Downloading modules in $dir..."; \
      (cd "$dir" && go mod download); \
    done
