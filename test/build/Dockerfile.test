FROM golang:1.25-alpine

RUN apk add --no-cache bash curl git jq build-base binutils-gold docker-cli

RUN curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 && \
    chmod 700 get_helm.sh && \
    VERIFY_CHECKSUM=false ./get_helm.sh && \
    rm get_helm.sh

RUN curl -L https://github.com/yannh/kubeconform/releases/latest/download/kubeconform-linux-amd64.tar.gz | tar xz && \
    mv kubeconform /usr/bin/kubeconform && \
    chmod +x /usr/bin/kubeconform

ENV GOPATH=/go
ENV GOCACHE=/go/cache
ENV CGO_ENABLED=1

WORKDIR /workspace

# Copy all Go source trees.
# Composition tests use a `replace` directive pointing to test/common/crossplane,
# so all three trees must be present together before module download.
COPY functions/ functions/
COPY test/common/crossplane/ test/common/crossplane/
COPY compositions/ compositions/

# Pre-download modules for every Go module in the image.
RUN find functions test/common/crossplane compositions -name "go.mod" -exec dirname {} \; | sort | \
    while read dir; do \
      echo "Downloading modules: $dir" && (cd "$dir" && go mod download); \
    done

# Pre-compile function main packages so `go run .` at test time is fast.
RUN find functions -mindepth 1 -maxdepth 1 -type d -not -name "common" | \
    while read dir; do \
      echo "Pre-building function: $dir" && (cd "$dir" && go build -o /dev/null . 2>/dev/null || true); \
    done

# Pre-compile all test packages (functions + composition tests) to warm the build cache.
RUN find functions compositions -name "go.mod" -exec dirname {} \; | sort | \
    while read dir; do \
      echo "Pre-compiling tests: $dir" && (cd "$dir" && go test -run=^$ ./... 2>/dev/null || true); \
    done