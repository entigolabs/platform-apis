FROM --platform=$BUILDPLATFORM golang:1.25-alpine AS cacher

ARG TARGETARCH

ENV GOPATH=/go
ENV GOCACHE=/go/cache
ENV CGO_ENABLED=0

ENV GOOS=linux
ENV GOARCH=$TARGETARCH

WORKDIR /workspace

COPY functions/ functions/
COPY test/common/ test/common/
COPY compositions/ compositions/

RUN apk add --no-cache findutils

RUN find functions \
      -name "go.mod" -exec dirname {} \; | \
    xargs -P $(nproc) -I {} sh -c ' \
      echo "==> Pre-compiling {} for architecture: $GOARCH" && \
      cd "{}" && \
      go mod download && \
      go test -run=^$ ./... || true \
    '

RUN echo "==> Pre-compiling test/common for architecture: $GOARCH" && \
    cd test/common && \
    go mod download && \
    go test -run=^$ ./... || true

RUN echo "==> Pre-compiling compositions for architecture: $GOARCH" && \
    cd compositions && \
    go mod download && \
    go test -run=^$ ./... || true

FROM golang:1.25-alpine

RUN apk add --no-cache bash curl git jq build-base binutils-gold docker-cli

RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') && \
    curl -L "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${ARCH}" -o /usr/bin/yq && \
    chmod +x /usr/bin/yq

RUN curl -sL https://raw.githubusercontent.com/crossplane/crossplane/master/install.sh | sh && \
    mv crossplane /usr/bin/crossplane

RUN curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 && \
    chmod 700 get_helm.sh && \
    VERIFY_CHECKSUM=false ./get_helm.sh && \
    rm get_helm.sh

RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') && \
    curl -L "https://github.com/yannh/kubeconform/releases/latest/download/kubeconform-linux-${ARCH}.tar.gz" | tar xz && \
    mv kubeconform /usr/bin/kubeconform && \
    chmod +x /usr/bin/kubeconform

RUN ARCH=$(uname -m | sed 's/aarch64/arm64/') && \
    curl -L "https://github.com/kyverno/kyverno/releases/download/v1.17.1/kyverno-cli_v1.17.1_linux_${ARCH}.tar.gz" | tar xz && \
    mv kyverno /usr/bin/kyverno && \
    chmod +x /usr/bin/kyverno

ENV GOPATH=/go
ENV GOCACHE=/go/cache
ENV CGO_ENABLED=0

WORKDIR /workspace

COPY functions/ functions/
COPY test/common/ test/common/
COPY compositions/ compositions/

COPY --from=cacher /go/pkg/mod /go/pkg/mod
COPY --from=cacher /go/cache /go/cache